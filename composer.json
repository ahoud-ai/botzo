{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "botzo/sa-client",
    "type": "project",
    "description": "Botzo Saudi client WhatsApp SaaS workspace.",
    "keywords": ["botzo", "whatsapp", "saas", "saudi"],
    "require": {
        "php": "^8.2",
        "aws/aws-sdk-php": "^3.372",
        "dacoto/laravel-env-set": "^2.1",
        "guzzlehttp/guzzle": "^7.10",
        "inertiajs/inertia-laravel": "^2.0",
        "laravel/framework": "^12.0",
        "laravel/socialite": "^5.23",
        "laravel/tinker": "^2.10.1",
        "league/flysystem-aws-s3-v3": "^3.30",
        "maatwebsite/excel": "^3.1",
        "mews/purifier": "^3.4",
        "mpdf/mpdf": "8.2",
        "netflie/whatsapp-cloud-api": "^2.2",
        "openai-php/client": "^0.18.0",
        "php-ffmpeg/php-ffmpeg": "^1.3",
        "phpoffice/phpword": "^1.4",
        "propaganistas/laravel-phone": "^6.0",
        "pusher/pusher-php-server": "^7.2",
        "resend/resend-php": "^1.1",
        "smalot/pdfparser": "^2.12",
        "symfony/http-client": "^7.4",
        "symfony/mailgun-mailer": "^7.4",
        "symfony/postmark-mailer": "^7.4"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.1",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\": "modules/"
        },
        "files": [
            "app/Helpers/DateTimeHelper.php",
            "app/Helpers/CustomHelper.php"
        ],
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "check:hygiene": [
            "@php scripts/check-repo-hygiene.php"
        ],
        "check:dependency-audits": [
            "@php scripts/check-dependency-audits.php --format=json --strict"
        ],
        "check:architecture": [
            "@php artisan test tests/Feature/ArchitectureEnvBoundaryTest.php tests/Feature/ArchitectureBudgetGuardTest.php tests/Feature/RouteContractSnapshotTest.php tests/Unit/WhatsappAccountInspectionServiceTest.php"
        ],
        "lint:php": [
            "@php scripts/lint-foundation.php"
        ],
        "analyse:php": [
            "@php vendor/bin/phpstan analyse --memory-limit=1G"
        ],
        "build:prebuilt": [
            "npm run build",
            "@php scripts/refresh-prebuilt-build.php --format=json"
        ],
        "assets:ensure-prebuilt": [
            "@php scripts/ensure-prebuilt-build.php --format=json"
        ],
        "check:i18n-ar-en": [
            "@php scripts/i18n/check-ar-en.php --mode=strict"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php scripts/ensure-prebuilt-build.php --quiet"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
