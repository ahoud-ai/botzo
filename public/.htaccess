## ------------------------------
## Performance + Security Headers
## ------------------------------
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

## ------------------------------
## Compression (when modules exist)
## ------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css text/javascript application/javascript application/x-javascript application/json application/xml image/svg+xml application/rss+xml application/atom+xml font/ttf font/otf application/vnd.ms-fontobject
</IfModule>

<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/plain text/html text/xml text/css text/javascript application/javascript application/x-javascript application/json application/xml image/svg+xml application/rss+xml application/atom+xml font/ttf font/otf application/vnd.ms-fontobject
</IfModule>

## ------------------------------
## Static asset cache policy
## ------------------------------
<IfModule mod_expires.c>
    ExpiresActive On

    ExpiresByType text/css "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"
    ExpiresByType application/json "access plus 1 hour"

    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    # Detect build assets by request URI (works even with symlinked docroots).
    SetEnvIfExpr "%{REQUEST_URI} =~ m#^/build/assets/.+#" IS_BUILD_ASSET=1
    SetEnvIfExpr "%{REQUEST_URI} =~ m#^/prebuilt-build/assets/.+#" IS_PREBUILT_ASSET=1
    SetEnvIfExpr "%{REQUEST_URI} =~ m#^/build/manifest\\.json$#" IS_BUILD_MANIFEST=1

    Header set Cache-Control "public, max-age=31536000, immutable" env=IS_BUILD_ASSET
    Header set Cache-Control "public, max-age=31536000, immutable" env=IS_PREBUILT_ASSET
    Header set Cache-Control "public, max-age=300, must-revalidate" env=IS_BUILD_MANIFEST

    # Keep compressed variants safe for shared caches.
    <FilesMatch "\.(css|js|mjs|map|json|png|jpe?g|gif|svg|webp|avif|ico|woff2?|ttf|otf)$">
        Header merge Vary "Accept-Encoding"
    </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Allow ACME challenge without redirecting the challenge path.
    RewriteCond %{REQUEST_URI} !^/\.well-known/ [NC]
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301,NE]

    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteRule ^$ index.php [L]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

<IfModule mod_dir.c>
    FallbackResource /index.php
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php82” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
